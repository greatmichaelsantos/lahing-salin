rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /salinlahi_config/{docId} {
      // Any authenticated session may read config (PIN is verified client-side)
      allow read: if request.auth != null;
      // Only allow writing pin and/or presPin — secret password gate is enforced in app code
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(["pin", "presPin"])
        && (!("pin" in request.resource.data) || (request.resource.data.pin is string && request.resource.data.pin.matches("^[0-9]{4}$")))
        && (!("presPin" in request.resource.data) || (request.resource.data.presPin is string && request.resource.data.presPin.matches("^[0-9]{4}$")));
    }

    match /salinlahi_scores/{docId} {
      // Any anonymously-authenticated visitor may read and add scores
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.score is number
        && request.resource.data.total is number
        && request.resource.data.pct is number
        && request.resource.data.ts is number;

      // Deletes are allowed for authenticated sessions (admin PIN protects the UI)
      allow delete: if request.auth != null;

      // Updates are never allowed
      allow update: if false;
    }
  }
}
